generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  passwordHash     String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  categories       Category[]
  transactions     Transaction[]
  budgets          Budget[]
  installmentPlans InstallmentPlan[]
  installmentItems InstallmentPayment[]
  fixedExpenses    FixedExpense[]
  yearlySummaries  YearlySummary[]
}

model Category {
  id           String          @id @default(cuid())
  name         String
  type         TransactionType
  color        String?
  icon         String?
  userId       String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  installmentPlans InstallmentPlan[]
  fixedExpenses FixedExpense[]

  @@unique([userId, name, type])
}

model FixedExpense {
  id         String   @id @default(cuid())
  title      String
  amount     Decimal  @db.Decimal(12, 2)
  categoryId String
  dayOfMonth Int      @default(1)
  startMonth Int
  startYear  Int
  endMonth   Int?
  endYear    Int?
  active     Boolean  @default(true)
  notes      String?
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId, active])
  @@index([categoryId])
}

model YearlySummary {
  id               String   @id @default(cuid())
  year             Int
  incomeTotal      Decimal  @db.Decimal(12, 2)
  expenseTotal     Decimal  @db.Decimal(12, 2)
  balance          Decimal  @db.Decimal(12, 2)
  monthlyBreakdown Json
  userId           String
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@index([userId, year])
}

model Transaction {
  id              String           @id @default(cuid())
  title           String
  amount          Decimal          @db.Decimal(12, 2)
  type            TransactionType
  categoryId      String
  date            DateTime
  notes           String?
  userId          String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  installmentPlan InstallmentPlan?

  @@index([userId, date])
  @@index([categoryId])
}

model Budget {
  id         String   @id @default(cuid())
  amount     Decimal  @db.Decimal(12, 2)
  month      Int
  year       Int
  categoryId String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@index([userId, month, year])
}

model InstallmentPlan {
  id               String               @id @default(cuid())
  transactionId    String               @unique
  totalAmount      Decimal              @db.Decimal(12, 2)
  installmentCount Int
  installmentAmount Decimal             @db.Decimal(12, 2)
  firstDueDate     DateTime
  userId           String
  categoryId       String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  transaction      Transaction          @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  payments         InstallmentPayment[]

  @@index([userId, firstDueDate])
}

model InstallmentPayment {
  id                String            @id @default(cuid())
  planId            String
  installmentNumber Int
  amount            Decimal           @db.Decimal(12, 2)
  dueDate           DateTime
  status            InstallmentStatus @default(PENDING)
  paidAt            DateTime?
  userId            String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  plan              InstallmentPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([planId, installmentNumber])
  @@index([userId, dueDate, status])
}
